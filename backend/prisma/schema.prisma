// Prisma schema for the GitHub Release Tracker.
//
// All ids are native Postgres UUIDs; FK columns reference them as @db.Uuid.
// Latest release is denormalized onto Repo (no Release history table). The
// per-user seen watermark lives on UserRepo.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SyncStatus {
  SUCCESS
  ERROR
  PENDING
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  handle       String     @unique
  createdAt    DateTime   @default(now())
  trackedRepos UserRepo[]
}

// Globally deduped — one row per GitHub repo.
model Repo {
  id                       String      @id @default(uuid()) @db.Uuid
  githubId                 Int         @unique
  owner                    String
  name                     String
  description              String?
  url                      String
  authorUrl                String
  avatarUrl                String?
  stars                    Int         @default(0)
  watchers                 Int         @default(0)
  forks                    Int         @default(0)
  languages                Json        @default("[]")
  latestReleaseVersion     String?
  latestReleasePublishedAt DateTime?
  latestReleaseUrl         String?
  lastSyncedAt             DateTime?
  lastSyncStatus           SyncStatus?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  trackedBy                UserRepo[]

  @@unique([owner, name])
}

// Tenancy edge + seen watermark.
model UserRepo {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @db.Uuid
  repoId                 String   @db.Uuid
  addedAt                DateTime @default(now())
  lastSeenReleaseVersion String?
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo                   Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([userId, repoId])
}
