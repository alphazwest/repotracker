# Backend environment — copy to .env and fill in.

# Postgres connection string. Matches docker-compose.yml defaults.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/release_tracker?schema=public"

# GitHub API token. OPTIONAL but recommended. Tracking/syncing public repos
# works unauthenticated (60 req/hr per IP). Setting a token raises the limit to
# 5,000 req/hr — recommended to avoid rate-limit errors on shared IPs. Create a
# fine-grained or classic PAT with public-repo read scope at
# https://github.com/settings/tokens
GITHUB_TOKEN=""

# Port the GraphQL server listens on (wired in ticket 005).
PORT=4000

# Background sync schedule as a cron expression (wired in ticket 006).
# Default: every 15 minutes.
SYNC_INTERVAL_CRON="*/15 * * * *"
